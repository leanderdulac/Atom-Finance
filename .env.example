# ════════════════════════════════════════════════════════════════
#  ATOM — Production Environment Template
#  Copy to .env.prod on the server and fill in the values.
#  NEVER commit the actual .env.prod to git.
# ════════════════════════════════════════════════════════════════

ATOM_ENV=production

# ── Security ─────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_WITH_GENERATED_KEY
ACCESS_TOKEN_EXPIRE_HOURS=24

# ── Database ──────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(16))"
POSTGRES_PASSWORD=REPLACE_WITH_GENERATED_PASSWORD
DATABASE_URL=postgresql+asyncpg://atom:REPLACE_WITH_GENERATED_PASSWORD@postgres:5432/atom_db
REDIS_URL=redis://redis:6379/0

# ── Domain ────────────────────────────────────────────────────────
FRONTEND_URL=https://atom.yourdomain.com
ALLOWED_ORIGINS=https://atom.yourdomain.com

# ── B3 Market Data ────────────────────────────────────────────────
# Free tier: 15 req/min — https://brapi.dev/register
BRAPI_TOKEN=

# ── AI Providers ──────────────────────────────────────────────────
# At least one is required for the AI Report to function.
ANTHROPIC_API_KEY=      # https://console.anthropic.com
OPENAI_API_KEY=         # https://platform.openai.com
XAI_API_KEY=            # https://x.ai/api
PERPLEXITY_API_KEY=     # https://www.perplexity.ai/settings/api

# ── B3 Options Data (optional — enriches AI analysis) ─────────────
BRIDGEWISE_TOKEN=       # https://bridgewise.com/integrations
BRIDGEWISE_BASE_URL=https://rest.bridgewise.com
