# ─── ATOM Environment Variables ───────────────────────────────────────────────
# Copy this file to .env and fill in the values before running.

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-generate-a-real-random-secret

# Token expiry in hours (default: 24)
ACCESS_TOKEN_EXPIRE_HOURS=24

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
# ALLOWED_ORIGINS=http://localhost:5173,https://your-domain.com
FRONTEND_URL=http://localhost:5173

# ── Databases ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://atom:atom@postgres:5432/atom_db
MONGODB_URL=mongodb://mongo:27017/atom_realtime
REDIS_URL=redis://redis:6379/0

# ── External Data Providers ───────────────────────────────────────────────────
# OpenBB token (optional — get from https://my.openbb.co)
# OPENBB_TOKEN=your-openbb-token-here

# ── Application ───────────────────────────────────────────────────────────────
# Set to "production" to disable debug features
ENVIRONMENT=development
